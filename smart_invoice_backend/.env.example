# ── Base de datos MySQL ────────────────────────────────────────
# En local usar localhost; en Docker Compose usar el nombre del servicio "mysql"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_invoice
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# ── Seguridad JWT ──────────────────────────────────────────────
SECRET_KEY=cambia_esta_clave_secreta_muy_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Almacenamiento de archivos ─────────────────────────────────
UPLOAD_DIR=uploads
REPORTS_DIR=reports
MAX_FILE_SIZE_MB=20

# ── CORS (orígenes permitidos, separados por coma) ─────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── OCR / Tesseract ────────────────────────────────────────────
# Ruta al binario de Tesseract (Windows). En Linux/Docker dejar vacío (usa PATH).
TESSERACT_CMD=
# Ruta a Poppler/bin para pdf2image (Windows). En Linux/Docker dejar vacío.
POPPLER_PATH=
OCR_LANG=spa+eng

# ── SMTP para envío de correos ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
EMAIL_FROM=SmartInvoice <tu_correo@gmail.com>

# ── RPA (Playwright) ───────────────────────────────────────────
RPA_FORM_URL=http://localhost:3000/formulario-simulado
RPA_HEADLESS=true
